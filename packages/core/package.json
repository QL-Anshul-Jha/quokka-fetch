{
  "name": "@blazion/core",
  "version": "1.0.1",
  "description": "Core engine for Blazion — a lightweight, strictly-typed fetch wrapper",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "keywords": [
    "blazion",
    "fetch",
    "http",
    "api",
    "typescript",
    "zero-dependency",
    "no-third-party",
    "no-deps",
    "third-party-free",
    "fetch-with-retry",
    "fetch-with-cache",
    "fetch-with-timeout"
  ],
  "scripts": {
    "build": "tsc --build && tsup",
    "prepublishOnly": "npm run build",
    "lint": "eslint src --fix"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
