{
  "name": "@blazion/core",
  "version": "1.0.0",
  "description": "Core engine for Blazion — a lightweight, strictly-typed fetch wrapper",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/test.*"
  ],
  "keywords": ["blazion", "fetch", "http", "api", "typescript", "zero-dependency"],
  "scripts": {
    "build": "tsc"
  }
}
