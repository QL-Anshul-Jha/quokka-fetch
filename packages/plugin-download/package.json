{
  "name": "@blazion/plugin-download-progress",
  "version": "1.0.0",
  "description": "Download progress plugin for Blazion — stream-based download tracking",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "keywords": ["blazion", "download", "progress", "fetch", "stream", "plugin"],
  "peerDependencies": {
    "@blazion/core": ">=1.0.0"
  },
  "scripts": {
    "build": "tsc --build && tsup",
    "lint": "eslint src --fix"
  }
}
