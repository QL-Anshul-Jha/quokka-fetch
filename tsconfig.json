{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@blazion/core": ["packages/core/src/index.ts"]
    }
  },
  "exclude": ["packages/**/tsup.config.ts", "**/dist/*"],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/plugin-cache" },
    { "path": "packages/plugin-retry" },
    { "path": "packages/plugin-download" },
    { "path": "packages/plugin-upload" }
  ]
}
