#!/usr/bin/env sh

# ‚îÅ‚îÅ‚îÅ Domain Guard: Only @quokkalabs.com emails can commit ‚îÅ‚îÅ‚îÅ
EMAIL=$(git config user.email)
DOMAIN="@quokkalabs.com"

if echo "$EMAIL" | grep -qv "$DOMAIN$"; then
  echo ""
  echo "‚ùå COMMIT BLOCKED"
  echo "   Your email: $EMAIL"
  echo "   Required domain: *$DOMAIN"
  echo ""
  echo "   Fix it with:"
  echo "   git config user.email \"yourname$DOMAIN\""
  echo ""
  exit 1
fi

npx lint-staged
